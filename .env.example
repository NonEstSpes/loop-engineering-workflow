# LLM provider API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
KIMI_API_KEY=

# LangSmith tracing
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=

# Network / proxy (forwarded to all MCP server subprocesses)
# Optional: HTTP/HTTPS proxy URLs for reaching trackers / MCP servers behind a
# corporate network. NO_PROXY excludes hosts from the proxy (comma-separated,
# e.g. localhost,127.0.0.1,.corp).
# HTTP_PROXY=
# HTTPS_PROXY=
# NO_PROXY=
# Optional: path to a PEM bundle of trusted CA certificates. Use this for
# trackers / MCP servers that use a corporate or self-signed certificate
# (forwarded as both SSL_CERT_FILE and REQUESTS_CA_BUNDLE so httpx, requests
# and curl all honour it).
# SSL_CERT_FILE=

# Task source provider (e.g., redmine, jira, mock)
TASK_SOURCE_PROVIDER=

# Redmine
# Requires `uv`/`uvx` (https://docs.astral.sh/uv/) in PATH to launch the
# runekaagaard/mcp-redmine MCP server over stdio.
REDMINE_URL=
REDMINE_API_KEY=
# Optional: Host header when Redmine is behind a reverse proxy / virtual host.
REDMINE_HOST_HEADER=
# Optional: override the MCP server launch command (default: uvx).
REDMINE_MCP_COMMAND=uvx
# Optional: override the MCP server args (default: --from mcp-redmine mcp-redmine).
REDMINE_MCP_ARGS=--from mcp-redmine mcp-redmine

# Jira
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=

# Git forge tokens
GITHUB_TOKEN=
GITLAB_TOKEN=

# Notification webhooks
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# Telegram (notifications + human-in-the-loop approvals)
# Create a bot via @BotFather and copy the token here.
TELEGRAM_BOT_TOKEN=
# Target chat id (user or group). Use @userinfobot or send a message to the
# bot and inspect getUpdates to find the numeric id.
TELEGRAM_CHAT_ID=
# Optional: override the Telegram Bot API base URL (e.g. a local Bot API server).
# TELEGRAM_API_BASE=https://api.telegram.org

# ── Daemon (autonomous mode) ──────────────────────────────────────────────
# Override HITL strategy without editing YAML:
# DEVFLOW_HITL_STRATEGY=per_plan   # per_plan | full_detail | end_of_day

# ── ntfy push notifications ───────────────────────────────────────────────
# NTFY_SERVER=https://ntfy.sh       # or self-hosted URL
# NTFY_TOPIC=devflow-your-team      # topic to publish to
# NTFY_TOKEN=                       # optional, for auth on self-hosted

# ── Email (SMTP) notifications ────────────────────────────────────────────
# SMTP_HOST=smtp.corp.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=devflow-bot@corp.com
# EMAIL_TO=dev-team@corp.com
